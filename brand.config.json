{
    "brand_name": "Experttrader",
    "brand_domain": "experttrader.com",
    "brand_hostname": {
        "staging": "staging.experttrader.com/dashboard",
        "production": "experttrader.com/dashboard"
    },
    "domain_name": "Experttrader.com",
    "colors": {
        "primary": "#00848c",
        "secondary": "#037272",
        "tertiary": "#fec20f",
        "success": "#10b981",
        "danger": "#ef4444",
        "warning": "#fccf17",
        "info": "#00848c",
        "neutral": "#6b7280",
        "black": "#1c1f4c",
        "white": "#ffffff",
        "grey": {
            "50": "#f8f8f7",
            "100": "#edebd9",
            "200": "#e2e0d0",
            "300": "#c8c6b8",
            "400": "#94a3b8",
            "500": "#64748b",
            "600": "#475569",
            "700": "#334155",
            "800": "#1e293b",
            "900": "#1c1f4c"
        }
    },
    "typography": {
        "font_family": {
            "primary": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif",
            "secondary": "'Inter', Georgia, 'Times New Roman', Times, serif",
            "monospace": "'JetBrains Mono', 'Courier New', Courier, monospace"
        },
        "font_sizes": {
            "xs": "0.75rem",
            "sm": "0.875rem",
            "base": "1rem",
            "lg": "1.125rem",
            "xl": "1.25rem",
            "2xl": "1.5rem",
            "3xl": "1.875rem",
            "4xl": "2.25rem"
        }
    },
    "color_variants": {
        "light_variants": [100, 200, 300, 400, 500],
        "dark_variants": [600, 700, 800, 900],
        "opacity_variants": [10, 20, 30, 40, 50, 60, 70, 80, 90]
    },
    "theme_config": {
        "enable_dynamic_themes": true,
        "auto_generate_variants": true,
        "css_variable_prefix": "--brand"
    },
    "platform": {
        "name": "Experttrader",
        "logo": {
            "type": "component",
            "component_name": "BrandLogo",
            "alt_text": "Experttrader",
            "link_url": "/",
            "show_text": false,
            "text": "Experttrader"
        },
        "footer": {
            "enable_language_settings": false,
            "enable_theme_toggle": false
        },
        "hostname": {
            "production": {
                "com": "bot.experttrader.com"
            },
            "staging": {
                "com": "staging-bot.experttrader.com"
            }
        },
        "auth2_url": {
            "production": "https://auth.deriv.com/oauth2/",
            "staging": "https://staging-auth.deriv.com/oauth2/"
        },
        "derivws": {
            "url": {
                "staging": "https://staging-api.derivws.com/trading/v1/",
                "production": "https://api.derivws.com/trading/v1/"
            },
            "directories": {
                "options": "options/",
                "derivatives": "derivatives/"
            }
        }
    }
}
